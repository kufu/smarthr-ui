{
  "extends": "./tsconfig.json",
  "exclude": [
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.stories.tsx",
    "src/**/stories/*.tsx",
    "src/**/__tests__"
  ],
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "./lib",
    "declaration": true,
    "types": ["node", "react"]
  },
  "include": ["src/**/*"]
}
